{
  "identifier": "overlay-default",
  "description": "Default permissions for the overlay window",
  "windows": ["overlay"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-always-on-top"
  ]
}
